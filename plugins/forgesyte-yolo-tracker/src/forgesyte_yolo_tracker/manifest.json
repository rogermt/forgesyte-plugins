{
  "id": "yolo-tracker",
  "name": "YOLO Tracker",
  "version": "1.0.0",
  "description": "ForgeSyte plugin for football player, ball, pitch, and radar analysis using YOLO + Supervision.",
  "author": "Roger",
  "license": "MIT",
  "entrypoint": "forgesyte_yolo_tracker.plugin",
  "type": "yolo",
  "capabilities": [
    "player_detection",
    "ball_detection",
    "pitch_detection",
    "radar"
  ],
  "tools": [
    {
      "id": "player_detection",
      "title": "Player Detection",
      "description": "Detect players in a single image.",
      "input_types": ["image_bytes"],
      "output_types": ["detections"],
      "capabilities": ["player_detection"],
      "inputs": {
        "image_bytes": "string",
        "device": "string",
        "annotated": "boolean"
      },
      "outputs": {
        "detections": "array",
        "annotated_image_base64": "string?"
      }
    },
    {
      "id": "ball_detection",
      "title": "Ball Detection",
      "description": "Detect the football in a single image.",
      "input_types": ["image_bytes"],
      "output_types": ["detections"],
      "capabilities": ["ball_detection"],
      "inputs": {
        "image_bytes": "string",
        "device": "string",
        "annotated": "boolean"
      },
      "outputs": {
        "detections": "array",
        "annotated_image_base64": "string?"
      }
    },
    {
      "id": "pitch_detection",
      "title": "Pitch Detection",
      "description": "Detect pitch keypoints for homography mapping.",
      "input_types": ["image_bytes"],
      "output_types": ["keypoints"],
      "capabilities": ["pitch_detection"],
      "inputs": {
        "image_bytes": "string",
        "device": "string",
        "annotated": "boolean"
      },
      "outputs": {
        "keypoints": "array",
        "annotated_image_base64": "string?"
      }
    },
    {
      "id": "radar",
      "title": "Radar View",
      "description": "Generate radar (bird's-eye) view of player positions.",
      "input_types": ["image_bytes"],
      "output_types": ["radar_points"],
      "capabilities": ["radar"],
      "inputs": {
        "image_bytes": "string",
        "device": "string",
        "annotated": "boolean"
      },
      "outputs": {
        "radar_points": "array",
        "annotated_image_base64": "string?"
      }
    },
    {
      "id": "video_ball_detection",
      "title": "Video Ball Detection",
      "description": "Run ball detection on video frames.",
      "input_types": ["video"],
      "output_types": ["frames"],
      "capabilities": ["ball_detection"],
      "inputs": {
        "video_path": "string",
        "device": "string"
      },
      "outputs": {
        "frames": "array",
        "total_frames": "integer"
      }
    },
    {
      "id": "video_pitch_detection",
      "title": "Video Pitch Detection",
      "description": "Run pitch detection on video frames.",
      "input_types": ["video"],
      "output_types": ["frames"],
      "capabilities": ["pitch_detection"],
      "inputs": {
        "video_path": "string",
        "device": "string"
      },
      "outputs": {
        "frames": "array",
        "total_frames": "integer"
      }
    },
    {
      "id": "video_radar",
      "title": "Video Radar",
      "description": "Generate radar view from video frames.",
      "input_types": ["video"],
      "output_types": ["frames"],
      "capabilities": ["radar"],
      "inputs": {
        "video_path": "string",
        "device": "string"
      },
      "outputs": {
        "frames": "array",
        "total_frames": "integer"
      }
    },
    {
      "id": "video_player_tracking",
      "title": "Video Player Tracking",
      "description": "Track players across video frames.",
      "input_types": ["video"],
      "output_types": ["frames"],
      "capabilities": ["player_detection"],
      "inputs": {
        "video_path": "string",
        "device": "string"
      },
      "outputs": {
        "frames": "array",
        "total_frames": "integer"
      }
    }
  ]
}
